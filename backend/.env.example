# Copy this file to .env and fill in values
# Never commit .env

PORT=3001
NODE_ENV=development

# SMTP (Gmail App Password — not your account password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=sidpatki123@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=sidpatki123@gmail.com
CONTACT_EMAIL=sidpatki123@gmail.com

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# CORS — must exactly match deployed frontend URL (no trailing slash)
ALLOWED_ORIGIN=https://siddhant-patki.github.io
